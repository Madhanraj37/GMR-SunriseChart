# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration template.
#
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
#
# NOTES
#  • Only variables prefixed with VITE_ are exposed to the app (Vite requirement).
#  • These values are BAKED IN at build time (`npm run build`) — they are NOT
#    read at runtime. Rebuild and redeploy after changing any of them.
#  • CLIENT_ID and TENANT_ID are public identifiers (they are visible in the
#    browser bundle of any SPA — this is expected and safe). They are NOT secrets.
#  • Never commit your real ".env" — it is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Microsoft Entra ID app registration → Overview → "Application (client) ID"
VITE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Microsoft Entra ID app registration → Overview → "Directory (tenant) ID"
VITE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Share link (from the browser address bar) of the SharePoint Excel file the
# dashboard reads. The app resolves it via the Graph /shares endpoint.
VITE_EXCEL_FILE_URL=https://yourtenant.sharepoint.com/:x:/s/YourSite/EXAMPLE_SHARE_TOKEN
