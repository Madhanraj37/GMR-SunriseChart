# Copy this file to ".env" and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the app.

# Azure app registration → Overview → "Application (client) ID"
VITE_CLIENT_ID=your-client-id-guid

# Azure app registration → Overview → "Directory (tenant) ID"
VITE_TENANT_ID=your-tenant-id-guid

# SharePoint Excel share link (copied from the browser)
VITE_EXCEL_FILE_URL=https://yourtenant.sharepoint.com/:x:/s/Site/xxxxx

# Comma-separated emails allowed to edit task status (others are view-only)
VITE_ADMIN_EMAILS=person1@example.com,person2@example.com
